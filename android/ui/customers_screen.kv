#:import Theme libs.utils.theme
<CustomerScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Customers"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Label:
                text: ""

        BoxLayout:
            orientation: "vertical"
            padding: [dp(8), dp(4)]
            spacing: dp(4)

            # Header row
            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(36)
                spacing: dp(8)
                Label:
                    text: "Customer Accounts"
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_PRIMARY
                    halign: "left"
                Widget:
                Button:
                    text: "+ Add Customer"
                    size_hint_x: 0.35
                    background_normal: ""
                    background_color: Theme.BTN_PRIMARY
                    color: Theme.TEXT_PRIMARY
                    on_press: root.show_form()

            # Search bar
            TextInput:
                id: customer_search
                size_hint_y: None
                height: dp(32)
                hint_text: "Search customers..."
                multiline: False
                foreground_color: Theme.TEXT_PRIMARY
                background_color: 0.15, 0.15, 0.18, 1
                on_text: root._rebuild(self.text)

            # Scrollable customer cards
            ScrollView:
                GridLayout:
                    id: customer_container
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(2)

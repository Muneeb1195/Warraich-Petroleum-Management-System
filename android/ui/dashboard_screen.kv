#:import Theme libs.utils.theme
# Custom StatCard widget
<StatCard>:
    canvas.before:
        Color:
            rgba: Theme.BG_CARD
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: root.accent_rgba
        Rectangle:
            pos: self.pos
            size: [dp(4), self.height]
    Label:
        text: root.icon
        size_hint_x: 0.2
        font_size: "24sp"
        color: Theme.TEXT_PRIMARY
    BoxLayout:
        orientation: "vertical"
        spacing: dp(2)
        Label:
            text: root.card_title
            font_size: "12sp"
            bold: True
            color: Theme.TEXT_DIM
            halign: "left"
            text_size: self.width, None
        Label:
            text: root.card_value
            font_size: "16sp"
            bold: True
            color: root.value_color
            halign: "left"
            text_size: self.width, None
        Label:
            text: root.trend_text
            font_size: "10sp"
            color: root.trend_color
            halign: "left"
            text_size: self.width, None


<DashboardScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Menu"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Dashboard"
                font_size: "20sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Button:
                text: "Refresh"
                size_hint_x: 0.2
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.refresh()

        # Scrollable dashboard content
        ScrollView:
            do_scroll_x: False
            GridLayout:
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                padding: [dp(8), dp(8)]

                # Subtitle
                Label:
                    text: "Real-time overview of sales, stock, and staff"
                    size_hint_y: None
                    height: dp(20)
                    color: Theme.TEXT_DIM
                    font_size: "12sp"
                    halign: "left"
                    text_size: self.width, None

                # Stat cards grid (2 columns x 4 rows)
                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: dp(640)
                    spacing: dp(8)
                    padding: [0, 0]

                    StatCard:
                        icon: "💰"
                        card_title: "TODAY'S SALES"
                        card_value: "Rs 0"
                        accent: "#58a6ff"
                        id: today_sales_card
                    StatCard:
                        icon: "📈"
                        card_title: "THIS MONTH"
                        card_value: "Rs 0"
                        accent: "#3fb950"
                        id: month_sales_card
                    StatCard:
                        icon: "📊"
                        card_title: "TODAY'S PROFIT"
                        card_value: "Rs 0"
                        accent: "#d29922"
                        id: profit_card
                    StatCard:
                        icon: "💸"
                        card_title: "TODAY'S EXPENSES"
                        card_value: "Rs 0"
                        accent: "#f85149"
                        id: expenses_card
                    StatCard:
                        icon: "⛽"
                        card_title: "FUEL TANKS"
                        card_value: "0"
                        accent: "#58a6ff"
                        id: tank_card
                    StatCard:
                        icon: "🛢️"
                        card_title: "LUBE PRODUCTS"
                        card_value: "0"
                        accent: "#3fb950"
                        id: lube_card
                    StatCard:
                        icon: "👥"
                        card_title: "ACTIVE STAFF"
                        card_value: "0"
                        accent: "#d29922"
                        id: staff_card
                    StatCard:
                        icon: "💵"
                        card_title: "PENDING PAYROLL"
                        card_value: "Rs 0"
                        accent: "#f85149"
                        id: payroll_card

                # Action buttons
                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(48)
                    spacing: dp(12)
                    padding: [0, dp(4)]

                    Button:
                        text: "🧾 Quick Sale"
                        background_normal: ""
                        background_color: Theme.BTN_QUICK_SALE
                        color: Theme.TEXT_PRIMARY
                        font_size: "15sp"
                        on_press: root.quick_sale()
                    Button:
                        text: "📋 Close Day"
                        background_normal: ""
                        background_color: Theme.BTN_AMBER
                        color: Theme.TEXT_DARK
                        font_size: "15sp"
                        on_press: root.close_day()

                # Spacer at bottom
                Widget:
                    size_hint_y: None
                    height: dp(20)

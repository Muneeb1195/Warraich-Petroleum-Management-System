#:import Theme libs.utils.theme
#:import RefreshableScrollView libs.utils.refresh_scroll.RefreshableScrollView
<InventoryScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Inventory Management"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Label:
                text: ""

        # Main content
        BoxLayout:
            orientation: "vertical"
            padding: [dp(6), dp(4)]
            spacing: dp(4)

            TabbedPanel:
                do_default_tab: False
                tab_width: self.width / 3
                background_color: Theme.BTN_NAV
                border: [0, 0, 0, 0]

                # ======= TANKS TAB =======
                TabbedPanelItem:
                    text: "Tanks"
                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(4)
                        padding: dp(4)

                        # Header row: title + add button
                        BoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(36)
                            spacing: dp(8)
                            Label:
                                text: "Fuel Storage Tanks"
                                font_size: "15sp"
                                bold: True
                                color: Theme.TEXT_PRIMARY
                                halign: "left"
                            Widget:
                            Button:
                                text: "+ Add Tank"
                                size_hint_x: 0.3
                                background_normal: ""
                                background_color: Theme.BTN_PRIMARY
                                color: Theme.TEXT_PRIMARY
                                on_press: root.show_tank_form()

                        # Search bar
                        TextInput:
                            id: tank_search
                            size_hint_y: None
                            height: dp(32)
                            hint_text: "Search tanks..."
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            on_text: root.filter_tanks(self.text)

                        # Scrollable tank cards
                        RefreshableScrollView:
                            refresh_callback: root._rebuild_tanks
                            GridLayout:
                                id: tank_container
                                cols: 1
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(2)

                # ======= PUMPS TAB =======
                TabbedPanelItem:
                    text: "Pumps"
                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(4)
                        padding: dp(4)

                        # Header
                        BoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(36)
                            spacing: dp(8)
                            Label:
                                text: "Dispensing Pumps"
                                font_size: "15sp"
                                bold: True
                                color: Theme.TEXT_PRIMARY
                                halign: "left"
                            Widget:
                            Button:
                                text: "+ Add Pump"
                                size_hint_x: 0.3
                                background_normal: ""
                                background_color: Theme.BTN_PRIMARY
                                color: Theme.TEXT_PRIMARY
                                on_press: root.show_pump_form()

                        # Search
                        TextInput:
                            id: pump_search
                            size_hint_y: None
                            height: dp(32)
                            hint_text: "Search pumps..."
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            on_text: root.filter_pumps(self.text)

                        # Scrollable pump cards
                        RefreshableScrollView:
                            refresh_callback: root._rebuild_pumps
                            GridLayout:
                                id: pump_container
                                cols: 1
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(2)

                # ======= LUBRICANTS TAB =======
                TabbedPanelItem:
                    text: "Lubricants"
                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(4)
                        padding: dp(4)

                        # Header
                        BoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(36)
                            spacing: dp(8)
                            Label:
                                text: "Lubricant Products"
                                font_size: "15sp"
                                bold: True
                                color: Theme.TEXT_PRIMARY
                                halign: "left"
                            Widget:
                            Button:
                                text: "+ Add Product"
                                size_hint_x: 0.3
                                background_normal: ""
                                background_color: Theme.BTN_PRIMARY
                                color: Theme.TEXT_PRIMARY
                                on_press: root.show_lube_form()

                        # Search
                        TextInput:
                            id: lube_search
                            size_hint_y: None
                            height: dp(32)
                            hint_text: "Search products..."
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            on_text: root.filter_lubes(self.text)

                        # Scrollable lube cards
                        RefreshableScrollView:
                            refresh_callback: root._rebuild_lubes
                            GridLayout:
                                id: lube_container
                                cols: 1
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(2)

#:import Theme libs.utils.theme
<MainScreen>:
    BoxLayout:
        orientation: "vertical"

        # Header bar
        BoxLayout:
            size_hint_y: 0.1
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "⛽ Warraich Petroleum"
                font_size: "20sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Label:
                text: "Management System"
                font_size: "12sp"
                color: Theme.TEXT_SECONDARY

        # Body with sidebar + content placeholder
        BoxLayout:
            orientation: "horizontal"

            # Sidebar
            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.45
                canvas.before:
                    Color:
                        rgba: Theme.BG_SIDEBAR
                    Rectangle:
                        pos: self.pos
                        size: self.size

                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 2

                        Button:
                            text: "📊 Dashboard"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "dashboard"
                        Button:
                            text: "⛽ Inventory"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "inventory"
                        Button:
                            text: "📦 Purchases"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "purchases"
                        Button:
                            text: "🧾 POS / Sales"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "pos"
                        Button:
                            text: "👥 Customers"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "customers"
                        Button:
                            text: "💰 Expenses"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "expenses"
                        Button:
                            text: "📈 Reports"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "reports"
                        Button:
                            text: "🔄 Shift Recon"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "reconciliation"
                        Button:
                            text: "👥 Staff"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "staff"
                        Button:
                            text: "⚙️ Settings"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.manager.current = "settings"

                        Label:
                            text: "v1.0"
                            size_hint_y: None
                            height: "32dp"
                            color: Theme.TEXT_VERSION

            # Content area placeholder
            BoxLayout:
                orientation: "vertical"
                padding: "16dp"
                canvas.before:
                    Color:
                        rgba: Theme.BG_MAIN
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "Welcome to Warraich Petroleum"
                    font_size: "24sp"
                    bold: True
                    color: Theme.TEXT_PRIMARY
                Label:
                    text: "Select a section from the sidebar to get started."
                    font_size: "15sp"
                    color: Theme.TEXT_SECONDARY

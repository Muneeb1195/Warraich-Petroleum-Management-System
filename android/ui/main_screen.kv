#:import Theme libs.utils.theme
<MainScreen>:
    BoxLayout:
        orientation: "vertical"

        # Header bar
        BoxLayout:
            size_hint_y: 0.08
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "☰"
                size_hint_x: 0.1
                font_size: "20sp"
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.toggle_drawer()
            Label:
                text: "Warraich Petroleum"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY

        # Body with collapsible sidebar + content placeholder
        BoxLayout:
            orientation: "horizontal"

            # Sidebar (collapsible)
            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.45 if root.drawer_open else 0
                opacity: 1 if root.drawer_open else 0
                canvas.before:
                    Color:
                        rgba: Theme.BG_SIDEBAR
                    Rectangle:
                        pos: self.pos
                        size: self.size

                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 2

                        Button:
                            text: "Dashboard"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'dashboard' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("dashboard")
                        Button:
                            text: "Inventory"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'inventory' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("inventory")
                        Button:
                            text: "Purchases"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'purchases' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("purchases")
                        Button:
                            text: "POS / Sales"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'pos' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("pos")
                        Button:
                            text: "Sales History"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'sales_history' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("sales_history")
                        Button:
                            text: "Customers"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'customers' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("customers")
                        Button:
                            text: "Expenses"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'expenses' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("expenses")
                        Button:
                            text: "Reports"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'reports' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("reports")
                        Button:
                            text: "Shift Recon"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'reconciliation' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("reconciliation")
                        Button:
                            text: "Staff"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'staff' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("staff")
                        Button:
                            text: "Settings"
                            size_hint_y: None
                            height: "44dp"
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY if root.active_screen == 'settings' else Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.go_to("settings")

                        Label:
                            text: "v1.0"
                            size_hint_y: None
                            height: "32dp"
                            color: Theme.TEXT_VERSION

            # Content area placeholder
            BoxLayout:
                orientation: "vertical"
                padding: "16dp"
                canvas.before:
                    Color:
                        rgba: Theme.BG_MAIN
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "Welcome to Warraich Petroleum"
                    font_size: "24sp"
                    bold: True
                    color: Theme.TEXT_PRIMARY
                Label:
                    text: "Select a section from the sidebar to get started."
                    font_size: "15sp"
                    color: Theme.TEXT_SECONDARY

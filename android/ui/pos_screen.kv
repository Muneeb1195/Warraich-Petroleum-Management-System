#:import Theme libs.utils.theme
<PosScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Point of Sale"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Label:
                text: ""

        # Items selection (top half)
        TabbedPanel:
            do_default_tab: False
            tab_width: self.width / 2
            background_color: Theme.BTN_NAV
            border: [0, 0, 0, 0]
            size_hint_y: 0.55
            TabbedPanelItem:
                text: "Fuel Sales"
                ScrollView:
                    do_scroll_x: False
                    GridLayout:
                        id: fuel_container
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(2)
            TabbedPanelItem:
                text: "Lube Sales"
                ScrollView:
                    do_scroll_x: False
                    GridLayout:
                        id: lube_container
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(2)

        # Cart & checkout (bottom half)
        BoxLayout:
            orientation: "vertical"
            size_hint_y: 0.38
            padding: [dp(6), dp(2)]
            spacing: dp(2)
            canvas.before:
                Color:
                    rgba: Theme.BG_CARD
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Options: Customer, Payment, GST
            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(36)
                spacing: dp(4)
                Label:
                    text: "Customer:"
                    size_hint_x: 0.22
                    color: Theme.TEXT_FIELD_LABEL
                    font_size: "12sp"
                Spinner:
                    id: customer_spinner
                    size_hint_x: 0.28
                    text: "Walk-in Customer"
                    values: ["Walk-in Customer"]
                    background_color: 0.18, 0.18, 0.22, 1
                    color: Theme.TEXT_PRIMARY
                    font_size: "12sp"
                Label:
                    text: "Pay:"
                    size_hint_x: 0.1
                    color: Theme.TEXT_FIELD_LABEL
                    font_size: "12sp"
                Spinner:
                    id: payment_spinner
                    size_hint_x: 0.18
                    text: "Cash"
                    values: ["Cash", "Card", "UPI", "Credit"]
                    background_color: 0.18, 0.18, 0.22, 1
                    color: Theme.TEXT_PRIMARY
                    font_size: "12sp"
                Label:
                    text: "GST:"
                    size_hint_x: 0.07
                    color: Theme.TEXT_FIELD_LABEL
                    font_size: "12sp"
                TextInput:
                    id: gst_input
                    size_hint_x: 0.12
                    multiline: False
                    input_filter: "float"
                    text: "18"
                    font_size: "12sp"
                    foreground_color: Theme.TEXT_PRIMARY
                    background_color: 0.15, 0.15, 0.18, 1
                    on_text: root.on_gst_change()

            # Cart items scrollable
            BoxLayout:
                orientation: "vertical"
                # Cart header row
                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(20)
                    spacing: dp(2)
                    padding: [dp(2), 0]
                    Label:
                        text: "Item"
                        size_hint_x: 0.32
                        bold: True
                        color: Theme.TEXT_SECONDARY
                        font_size: "9sp"
                    Label:
                        text: "Qty"
                        size_hint_x: 0.16
                        bold: True
                        color: Theme.TEXT_SECONDARY
                        font_size: "9sp"
                    Label:
                        text: "Rate"
                        size_hint_x: 0.16
                        bold: True
                        color: Theme.TEXT_SECONDARY
                        font_size: "9sp"
                    Label:
                        text: "Amt"
                        size_hint_x: 0.2
                        bold: True
                        color: Theme.TEXT_SECONDARY
                        font_size: "9sp"
                    Label:
                        text: ""
                        size_hint_x: 0.12

                # Cart items (scrollable, fills remaining space)
                ScrollView:
                    BoxLayout:
                        id: cart_container
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(1)

            # Totals + buttons (pinned at bottom)
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: dp(130)
                spacing: dp(1)
                padding: [dp(4), 0]

                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(18)
                    Label:
                        text: "Taxable:"
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                        halign: "left"
                    Label:
                        id: taxable_label
                        text: "Rs 0"
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"
                    Label:
                        text: "CGST:"
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                        halign: "left"
                    Label:
                        id: cgst_label
                        text: "Rs 0"
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"
                    Label:
                        text: "SGST:"
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                        halign: "left"
                    Label:
                        id: sgst_label
                        text: "Rs 0"
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"

                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(18)
                    Label:
                        text: "Total:"
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                        halign: "left"
                    Label:
                        id: total_label
                        text: "Rs 0"
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"
                    Label:
                        text: "R/Off:"
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                        halign: "left"
                    Label:
                        id: round_off_label
                        text: "Rs 0"
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"
                    Label:
                        text: "Grand:"
                        color: Theme.TEXT_BLUE_HEADER
                        font_size: "12sp"
                        bold: True
                        halign: "left"
                    Label:
                        id: grand_total_label
                        text: "Rs 0"
                        color: Theme.TEXT_GRAND_TOTAL
                        font_size: "12sp"
                        bold: True

                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(36)
                    spacing: dp(6)
                    padding: [dp(2), dp(2)]

                    Button:
                        text: "Clear"
                        background_normal: ""
                        background_color: Theme.BTN_DANGER_VARIANT
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"
                        on_press: root._clear_cart()

                    Button:
                        text: "Complete Sale"
                        background_normal: ""
                        background_color: Theme.BTN_PRIMARY
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"
                        on_press: root._checkout()

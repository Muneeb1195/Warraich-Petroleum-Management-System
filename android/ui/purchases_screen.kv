<PurchasesScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.12, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: 0.12, 0.12, 0.15, 1
                color: 1, 1, 1, 1
                on_press: root.go_back()
            Label:
                text: "Purchases"
                font_size: "18sp"
                bold: True
                color: 1, 1, 1, 1
            Button:
                text: "+ New"
                size_hint_x: 0.2
                background_normal: ""
                background_color: 0.15, 0.5, 0.15, 1
                color: 1, 1, 1, 1
                on_press: root.show_form()

        ScrollView:
            GridLayout:
                id: purchases_container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)
                padding: [0, dp(4)]

<ReconciliationScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.12, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: 0.12, 0.12, 0.15, 1
                color: 1, 1, 1, 1
                on_press: root.go_back()
            Label:
                text: "Shift Recon"
                font_size: "18sp"
                bold: True
                color: 1, 1, 1, 1
            Label:
                text: ""

        # Date + Shift controls
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: 0.07
            spacing: dp(6)
            padding: [dp(8), dp(4)]
            canvas.before:
                Color:
                    rgba: 0.09, 0.09, 0.12, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "Date:"
                size_hint_x: 0.12
                color: 0.8, 0.8, 0.8, 1
                font_size: "12sp"
            TextInput:
                id: date_input
                size_hint_x: 0.25
                multiline: False
                font_size: "11sp"
                foreground_color: 1, 1, 1, 1
                background_color: 0.15, 0.15, 0.18, 1
                on_text: root.on_date_shift_change()
            Label:
                text: "Shift:"
                size_hint_x: 0.1
                color: 0.8, 0.8, 0.8, 1
                font_size: "12sp"
            Spinner:
                id: shift_spinner
                size_hint_x: 0.18
                text: "Morning"
                values: ["Morning", "Evening", "Night"]
                background_color: 0.18, 0.18, 0.22, 1
                color: 1, 1, 1, 1
                font_size: "11sp"
                on_text: root.on_date_shift_change()
            Button:
                text: "Start"
                size_hint_x: 0.1
                background_normal: ""
                background_color: 0.15, 0.4, 0.15, 1
                color: 1, 1, 1, 1
                font_size: "11sp"
                on_press: root.start_shift()
            Button:
                text: "Close"
                size_hint_x: 0.1
                background_normal: ""
                background_color: 0.4, 0.15, 0.15, 1
                color: 1, 1, 1, 1
                font_size: "11sp"
                on_press: root.close_shift()

        # Pump readings header + rows
        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)

                GridLayout:
                    id: readings_container
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(2)

                # Reconcile button at bottom
                Button:
                    text: "Reconcile"
                    size_hint_y: None
                    height: dp(44)
                    background_normal: ""
                    background_color: 0.4, 0.4, 0.15, 1
                    color: 1, 1, 1, 1
                    font_size: "14sp"
                    on_press: root.reconcile()

                Widget:
                    size_hint_y: None
                    height: dp(20)

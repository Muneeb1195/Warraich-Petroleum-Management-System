#:import Theme libs.utils.theme
<ReconciliationScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Shift Recon"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Label:
                text: ""

        # Date + Shift controls
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: 0.07
            spacing: dp(6)
            padding: [dp(8), dp(4)]
            canvas.before:
                Color:
                    rgba: Theme.BG_CARD
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8),]
            Label:
                text: "Date:"
                size_hint_x: 0.1
                color: Theme.TEXT_FIELD_LABEL
                font_size: "14sp"
            TextInput:
                id: date_input
                size_hint_x: 0.18
                multiline: False
                font_size: "14sp"
                foreground_color: Theme.TEXT_PRIMARY
                background_color: 0.15, 0.15, 0.18, 1
                on_text: root.on_date_shift_change()
            Button:
                text: "Today"
                size_hint_x: 0.12
                font_size: "14sp"
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.set_date_today()
            Button:
                text: "Yest"
                size_hint_x: 0.1
                font_size: "14sp"
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.set_date_yesterday()
            Label:
                text: "Shift:"
                size_hint_x: 0.08
                color: Theme.TEXT_FIELD_LABEL
                font_size: "14sp"
            Spinner:
                id: shift_spinner
                size_hint_x: 0.18
                text: "Morning"
                values: ["Morning", "Evening", "Night"]
                background_color: 0.18, 0.18, 0.22, 1
                color: Theme.TEXT_PRIMARY
                font_size: "14sp"
                on_text: root.on_date_shift_change()
            Button:
                text: "Start"
                size_hint_x: 0.14
                background_normal: ""
                background_color: Theme.BTN_SECONDARY
                color: Theme.TEXT_PRIMARY
                font_size: "14sp"
                on_press: root.start_shift()
            Button:
                text: "Close"
                size_hint_x: 0.14
                background_normal: ""
                background_color: Theme.BTN_DANGER
                color: Theme.TEXT_PRIMARY
                font_size: "14sp"
                on_press: root.close_shift()

        # Pump readings header + rows
        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)

                GridLayout:
                    id: readings_container
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(2)

                # Reconcile button at bottom
                Button:
                    text: "Reconcile"
                    size_hint_y: None
                    height: dp(44)
                    background_normal: ""
                    background_color: Theme.BTN_OLIVE
                    color: Theme.TEXT_PRIMARY
                    font_size: "15sp"
                    on_press: root.reconcile()

                Widget:
                    size_hint_y: None
                    height: dp(24)

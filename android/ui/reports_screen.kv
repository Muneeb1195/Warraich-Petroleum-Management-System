#:import Theme libs.utils.theme
<ReportScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Reports"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Label:
                text: ""

        BoxLayout:
            orientation: "vertical"
            padding: [dp(8), dp(4)]
            spacing: dp(4)

            # Controls — split into 2 rows for portrait
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: dp(100)
                spacing: dp(4)

                # Row 1: Date range
                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(6)
                    Label:
                        text: "From:"
                        size_hint_x: 0.12
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                    TextInput:
                        id: from_input
                        size_hint_x: 0.38
                        hint_text: "YYYY-MM-DD"
                        multiline: False
                        foreground_color: Theme.TEXT_PRIMARY
                        background_color: 0.15, 0.15, 0.18, 1
                        font_size: "12sp"
                    Label:
                        text: "To:"
                        size_hint_x: 0.08
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                    TextInput:
                        id: to_input
                        size_hint_x: 0.38
                        hint_text: "YYYY-MM-DD"
                        multiline: False
                        foreground_color: Theme.TEXT_PRIMARY
                        background_color: 0.15, 0.15, 0.18, 1
                        font_size: "12sp"

                # Row 2: Date presets
                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(28)
                    spacing: dp(4)
                    Label:
                        text: "Quick:"
                        size_hint_x: 0.1
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "11sp"
                    Button:
                        text: "Today"
                        size_hint_x: 0.2
                        font_size: "11sp"
                        background_normal: ""
                        background_color: Theme.BTN_NAV
                        color: Theme.TEXT_PRIMARY
                        on_press: root._set_date_preset("today")
                    Button:
                        text: "Yesterday"
                        size_hint_x: 0.25
                        font_size: "11sp"
                        background_normal: ""
                        background_color: Theme.BTN_NAV
                        color: Theme.TEXT_PRIMARY
                        on_press: root._set_date_preset("yesterday")
                    Button:
                        text: "This Month"
                        size_hint_x: 0.28
                        font_size: "11sp"
                        background_normal: ""
                        background_color: Theme.BTN_NAV
                        color: Theme.TEXT_PRIMARY
                        on_press: root._set_date_preset("this_month")

                # Row 3: Report type + actions
                BoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(34)
                    spacing: dp(6)
                    Label:
                        text: "Report:"
                        size_hint_x: 0.12
                        color: Theme.TEXT_FIELD_LABEL
                        font_size: "12sp"
                    Spinner:
                        id: report_spinner
                        size_hint_x: 0.38
                        text: "Daily Summary"
                        values: ["Daily Summary", "Profit & Loss", "Sales Report", "Stock Report", "Expense Report", "Payroll Report"]
                        background_color: 0.18, 0.18, 0.22, 1
                        color: Theme.TEXT_PRIMARY
                        font_size: "12sp"
                    Button:
                        text: "Generate"
                        size_hint_x: 0.22
                        background_normal: ""
                        background_color: Theme.BTN_PRIMARY
                        color: Theme.TEXT_PRIMARY
                        on_press: root.generate()
                    Button:
                        text: "Export"
                        size_hint_x: 0.22
                        background_normal: ""
                        background_color: Theme.BTN_INFO
                        color: Theme.TEXT_PRIMARY
                        on_press: root.export_excel()

            # Summary label
            Label:
                id: summary_label
                size_hint_y: None
                height: dp(28)
                text: "Select report type and date range, then tap Generate."
                color: Theme.TEXT_SECONDARY
                font_size: "13sp"
                halign: "left"

            # Results table header + scrollable rows
            BoxLayout:
                orientation: "vertical"
                canvas.before:
                    Color:
                        rgba: Theme.BG_CARD
                    Rectangle:
                        pos: self.pos
                        size: self.size
                padding: [dp(4), dp(2)]

                ScrollView:
                    GridLayout:
                        id: result_container
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(1)

<ReportScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.12, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: 0.12, 0.12, 0.15, 1
                color: 1, 1, 1, 1
                on_press: root.go_back()
            Label:
                text: "Reports"
                font_size: "18sp"
                bold: True
                color: 1, 1, 1, 1
            Label:
                text: ""

        BoxLayout:
            orientation: "vertical"
            padding: [dp(8), dp(4)]
            spacing: dp(4)

            # Controls row
            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(36)
                spacing: dp(6)
                Label:
                    text: "From:"
                    size_hint_x: 0.08
                    color: 0.8, 0.8, 0.8, 1
                    font_size: "12sp"
                TextInput:
                    id: from_input
                    size_hint_x: 0.15
                    hint_text: "YYYY-MM-DD"
                    multiline: False
                    foreground_color: 1, 1, 1, 1
                    background_color: 0.15, 0.15, 0.18, 1
                    font_size: "12sp"
                Label:
                    text: "To:"
                    size_hint_x: 0.06
                    color: 0.8, 0.8, 0.8, 1
                    font_size: "12sp"
                TextInput:
                    id: to_input
                    size_hint_x: 0.15
                    hint_text: "YYYY-MM-DD"
                    multiline: False
                    foreground_color: 1, 1, 1, 1
                    background_color: 0.15, 0.15, 0.18, 1
                    font_size: "12sp"
                Label:
                    text: "Report:"
                    size_hint_x: 0.08
                    color: 0.8, 0.8, 0.8, 1
                    font_size: "12sp"
                Spinner:
                    id: report_spinner
                    size_hint_x: 0.25
                    text: "Daily Summary"
                    values: ["Daily Summary", "Profit & Loss", "Sales Report", "Stock Report", "Expense Report", "Payroll Report"]
                    background_color: 0.18, 0.18, 0.22, 1
                    color: 1, 1, 1, 1
                    font_size: "12sp"
                Button:
                    text: "Generate"
                    size_hint_x: 0.12
                    background_normal: ""
                    background_color: 0.15, 0.5, 0.15, 1
                    color: 1, 1, 1, 1
                    on_press: root.generate()
                Button:
                    text: "Export Excel"
                    size_hint_x: 0.15
                    background_normal: ""
                    background_color: 0.2, 0.3, 0.5, 1
                    color: 1, 1, 1, 1
                    on_press: root.export_excel()

            # Summary label
            Label:
                id: summary_label
                size_hint_y: None
                height: dp(28)
                text: "Select report type and date range, then tap Generate."
                color: 0.6, 0.6, 0.6, 1
                font_size: "13sp"
                halign: "left"

            # Results table header + scrollable rows
            BoxLayout:
                orientation: "vertical"
                canvas.before:
                    Color:
                        rgba: 0.09, 0.09, 0.12, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                padding: [dp(4), dp(2)]

                ScrollView:
                    GridLayout:
                        id: result_container
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(1)

<SettingsScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.12, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: 0.12, 0.12, 0.15, 1
                color: 1, 1, 1, 1
                on_press: root.go_back()
            Label:
                text: "Settings"
                font_size: "18sp"
                bold: True
                color: 1, 1, 1, 1
            Button:
                text: "Save"
                size_hint_x: 0.2
                background_normal: ""
                background_color: 0.15, 0.5, 0.15, 1
                color: 1, 1, 1, 1
                on_press: root.save()

        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                padding: [dp(12), dp(8)]

                # Business Info
                Label:
                    text: "Business Info"
                    size_hint_y: None
                    height: dp(28)
                    font_size: "14sp"
                    bold: True
                    color: 0.6, 0.8, 1, 1
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(200)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: 0.1, 0.1, 0.13, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Name:"
                            size_hint_x: 0.3
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: biz_name
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Address:"
                            size_hint_x: 0.3
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: biz_address
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Phone:"
                            size_hint_x: 0.3
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: biz_phone
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "GSTIN:"
                            size_hint_x: 0.3
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: biz_gstin
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                # Fuel Rates
                Label:
                    text: "Fuel Rates"
                    size_hint_y: None
                    height: dp(28)
                    font_size: "14sp"
                    bold: True
                    color: 0.6, 0.8, 1, 1
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: 0.1, 0.1, 0.13, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Petrol (Rs/L):"
                            size_hint_x: 0.4
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: petrol_rate
                            size_hint_x: 0.6
                            multiline: False
                            input_filter: "float"
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Diesel (Rs/L):"
                            size_hint_x: 0.4
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: diesel_rate
                            size_hint_x: 0.6
                            multiline: False
                            input_filter: "float"
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                # GST Settings
                Label:
                    text: "GST Settings"
                    size_hint_y: None
                    height: dp(28)
                    font_size: "14sp"
                    bold: True
                    color: 0.6, 0.8, 1, 1
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(200)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: 0.1, 0.1, 0.13, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Default GST %:"
                            size_hint_x: 0.35
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: default_gst
                            size_hint_x: 0.65
                            multiline: False
                            input_filter: "float"
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "HSN Petrol:"
                            size_hint_x: 0.35
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: hsn_petrol
                            size_hint_x: 0.65
                            multiline: False
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "HSN Diesel:"
                            size_hint_x: 0.35
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: hsn_diesel
                            size_hint_x: 0.65
                            multiline: False
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "HSN Lube:"
                            size_hint_x: 0.35
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: hsn_lube
                            size_hint_x: 0.65
                            multiline: False
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                # Regional
                Label:
                    text: "Regional"
                    size_hint_y: None
                    height: dp(28)
                    font_size: "14sp"
                    bold: True
                    color: 0.6, 0.8, 1, 1
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: 0.1, 0.1, 0.13, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Currency Symbol:"
                            size_hint_x: 0.4
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: currency_symbol
                            size_hint_x: 0.6
                            multiline: False
                            text: "Rs."
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Date Format:"
                            size_hint_x: 0.4
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: date_format
                            size_hint_x: 0.6
                            multiline: False
                            text: "DD/MM/YYYY"
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                # Cloud Backup
                Label:
                    text: "Cloud Backup (HTTP POST)"
                    size_hint_y: None
                    height: dp(28)
                    font_size: "14sp"
                    bold: True
                    color: 0.6, 0.8, 1, 1
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(140)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: 0.1, 0.1, 0.13, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Backup URL:"
                            size_hint_x: 0.3
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: backup_url
                            size_hint_x: 0.7
                            multiline: False
                            hint_text: "https://example.com/upload"
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "11sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)
                        Label:
                            id: backup_status
                            text: "Last: Never"
                            size_hint_x: 0.5
                            color: 0.6, 0.6, 0.6, 1
                            font_size: "11sp"
                        Button:
                            text: "Backup Now"
                            size_hint_x: 0.4
                            background_normal: ""
                            background_color: 0.15, 0.4, 0.15, 1
                            color: 1, 1, 1, 1
                            font_size: "12sp"
                            on_press: root.backup_now()

                # Printer (Network ESC/POS)
                Label:
                    text: "Printer (Network)"
                    size_hint_y: None
                    height: dp(28)
                    font_size: "14sp"
                    bold: True
                    color: 0.6, 0.8, 1, 1
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: 0.1, 0.1, 0.13, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "IP Address:"
                            size_hint_x: 0.35
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: printer_host
                            size_hint_x: 0.65
                            multiline: False
                            hint_text: "192.168.1.100"
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        Label:
                            text: "Port:"
                            size_hint_x: 0.35
                            color: 0.8, 0.8, 0.8, 1
                            font_size: "12sp"
                        TextInput:
                            id: printer_port
                            size_hint_x: 0.65
                            multiline: False
                            text: "9100"
                            input_filter: "int"
                            foreground_color: 1, 1, 1, 1
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"

                # spacer at bottom
                Widget:
                    size_hint_y: None
                    height: dp(20)

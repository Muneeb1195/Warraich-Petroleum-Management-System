#:import Theme libs.utils.theme
<SettingsScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Settings"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Button:
                text: "Save"
                size_hint_x: 0.2
                background_normal: ""
                background_color: Theme.BTN_PRIMARY
                color: Theme.TEXT_PRIMARY
                on_press: root.save()

        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                padding: [dp(12), dp(8)]

                # Business Info
                Label:
                    text: "Business Info"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(200)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Name:"
                            size_hint_x: 0.3
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: biz_name
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Address:"
                            size_hint_x: 0.3
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: biz_address
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Phone:"
                            size_hint_x: 0.3
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: biz_phone
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "GSTIN:"
                            size_hint_x: 0.3
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: biz_gstin
                            size_hint_x: 0.7
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                # Fuel Rates
                Label:
                    text: "Fuel Rates"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Petrol (Rs/L):"
                            size_hint_x: 0.4
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: petrol_rate
                            size_hint_x: 0.6
                            multiline: False
                            input_filter: "float"
                            input_type: "number"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Diesel (Rs/L):"
                            size_hint_x: 0.4
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: diesel_rate
                            size_hint_x: 0.6
                            multiline: False
                            input_filter: "float"
                            input_type: "number"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                # GST Settings
                Label:
                    text: "GST Settings"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(200)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Default GST %:"
                            size_hint_x: 0.35
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: default_gst
                            size_hint_x: 0.65
                            multiline: False
                            input_filter: "float"
                            input_type: "number"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "HSN Petrol:"
                            size_hint_x: 0.35
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: hsn_petrol
                            size_hint_x: 0.65
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "HSN Diesel:"
                            size_hint_x: 0.35
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: hsn_diesel
                            size_hint_x: 0.65
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "HSN Lube:"
                            size_hint_x: 0.35
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: hsn_lube
                            size_hint_x: 0.65
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                # Regional
                Label:
                    text: "Regional"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Currency Symbol:"
                            size_hint_x: 0.4
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: currency_symbol
                            size_hint_x: 0.6
                            multiline: False
                            text: "Rs."
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Date Format:"
                            size_hint_x: 0.4
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: date_format
                            size_hint_x: 0.6
                            multiline: False
                            text: "DD/MM/YYYY"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                # Google Drive Backup
                Label:
                    text: "Google Drive Backup"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(120)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Status:"
                            size_hint_x: 0.25
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        Label:
                            id: drive_status
                            text: "Not connected"
                            size_hint_x: 0.75
                            color: Theme.TEXT_SECONDARY
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)
                        Button:
                            id: connect_btn
                            text: "Connect to Drive"
                            size_hint_x: 0.5
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY
                            color: Theme.TEXT_PRIMARY
                            font_size: "14sp"
                        Button:
                            text: "Backup Now"
                            size_hint_x: 0.4
                            background_normal: ""
                            background_color: Theme.BTN_SECONDARY
                            color: Theme.TEXT_PRIMARY
                            font_size: "14sp"
                            on_press: root.drive_backup_now()

                # Restore
                Label:
                    text: "Restore"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)
                        Button:
                            text: "Restore from Cloud"
                            size_hint_x: 0.5
                            background_normal: ""
                            background_color: Theme.BTN_INFO
                            color: Theme.TEXT_PRIMARY
                            font_size: "14sp"
                            on_press: root.show_cloud_restore()
                        Button:
                            text: "Restore from Local"
                            size_hint_x: 0.45
                            background_normal: ""
                            background_color: Theme.BTN_SECONDARY
                            color: Theme.TEXT_PRIMARY
                            font_size: "14sp"
                            on_press: root.show_local_restore()

                # App PIN Lock
                Label:
                    text: "App PIN Lock"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Status:"
                            size_hint_x: 0.25
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        Label:
                            id: pin_status
                            text: "Not set"
                            size_hint_x: 0.75
                            color: Theme.TEXT_SECONDARY
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)
                        Button:
                            id: set_pin_btn
                            text: "Set PIN"
                            size_hint_x: 0.5
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY
                            color: Theme.TEXT_PRIMARY
                            font_size: "14sp"
                        Button:
                            text: "Disable PIN"
                            size_hint_x: 0.4
                            background_normal: ""
                            background_color: Theme.BTN_DANGER
                            color: Theme.TEXT_PRIMARY
                            font_size: "14sp"
                            on_press: root.disable_pin_action()

                # Printer (Network ESC/POS)
                Label:
                    text: "Printer (Network)"
                    size_hint_y: None
                    height: dp(32)
                    font_size: "15sp"
                    bold: True
                    color: Theme.TEXT_BLUE_HEADER
                    halign: "left"
                    text_size: self.width, None

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(6)
                    padding: [dp(8), dp(8)]
                    canvas.before:
                        Color:
                            rgba: Theme.BG_PANEL
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8),]

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "IP Address:"
                            size_hint_x: 0.35
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: printer_host
                            size_hint_x: 0.65
                            multiline: False
                            hint_text: "192.168.1.100"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(42)
                        Label:
                            text: "Port:"
                            size_hint_x: 0.35
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "14sp"
                        TextInput:
                            id: printer_port
                            size_hint_x: 0.65
                            multiline: False
                            text: "9100"
                            input_filter: "int"
                            input_type: "number"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "14sp"

                # spacer at bottom
                Widget:
                    size_hint_y: None
                    height: dp(24)

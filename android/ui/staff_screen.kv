#:import Theme libs.utils.theme
#:import RefreshableScrollView libs.utils.refresh_scroll.RefreshableScrollView
<StaffScreen>:
    BoxLayout:
        orientation: "vertical"

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            canvas.before:
                Color:
                    rgba: Theme.BG_HEADER
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "< Back"
                size_hint_x: 0.15
                background_normal: ""
                background_color: Theme.BTN_NAV
                color: Theme.TEXT_PRIMARY
                on_press: root.go_back()
            Label:
                text: "Staff & Payroll"
                font_size: "18sp"
                bold: True
                color: Theme.TEXT_PRIMARY
            Label:
                text: ""

        TabbedPanel:
            do_default_tab: False
            tab_width: self.width / 3
            background_color: Theme.BTN_NAV
            border: [0, 0, 0, 0]

            # ========== EMPLOYEES TAB ==========
            TabbedPanelItem:
                text: "Employees"
                BoxLayout:
                    orientation: "vertical"
                    spacing: dp(4)
                    padding: dp(4)

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        spacing: dp(8)
                        Label:
                            text: "Staff Members"
                            font_size: "15sp"
                            bold: True
                            color: Theme.TEXT_PRIMARY
                            halign: "left"
                        Widget:
                        Button:
                            text: "+ Add Employee"
                            size_hint_x: 0.35
                            background_normal: ""
                            background_color: Theme.BTN_PRIMARY
                            color: Theme.TEXT_PRIMARY
                            on_press: root.show_employee_form()

                    TextInput:
                        id: employee_search
                        size_hint_y: None
                        height: dp(32)
                        hint_text: "Search employees..."
                        multiline: False
                        foreground_color: Theme.TEXT_PRIMARY
                        background_color: 0.15, 0.15, 0.18, 1
                        on_text: root.filter_employees(self.text)

                    RefreshableScrollView:
                        refresh_callback: root._rebuild_employees
                        GridLayout:
                            id: employee_container
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(2)

            # ========== ATTENDANCE TAB ==========
            TabbedPanelItem:
                text: "Attendance"
                BoxLayout:
                    orientation: "vertical"
                    spacing: dp(4)
                    padding: dp(4)

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        spacing: dp(4)
                        Label:
                            text: "Date:"
                            size_hint_x: 0.06
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "12sp"
                        TextInput:
                            id: attendance_date
                            size_hint_x: 0.14
                            hint_text: "YYYY-MM-DD"
                            text: ""
                            multiline: False
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"
                            on_text: root._rebuild_attendance()
                        Button:
                            text: "Today"
                            size_hint_x: 0.1
                            font_size: "10sp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.set_attendance_today()
                        Button:
                            text: "Yest"
                            size_hint_x: 0.08
                            font_size: "10sp"
                            background_normal: ""
                            background_color: Theme.BTN_NAV
                            color: Theme.TEXT_PRIMARY
                            on_press: root.set_attendance_yesterday()
                        Label:
                            text: "Shift:"
                            size_hint_x: 0.06
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "12sp"
                        Spinner:
                            id: attendance_shift
                            size_hint_x: 0.14
                            text: "Morning"
                            values: ["Morning", "Evening", "Night"]
                            background_color: 0.18, 0.18, 0.22, 1
                            color: Theme.TEXT_PRIMARY
                            font_size: "12sp"
                            on_text: root._rebuild_attendance()
                        Widget:
                        Button:
                            text: "Mark All Present"
                            size_hint_x: 0.25
                            background_normal: ""
                            background_color: Theme.BTN_SECONDARY
                            color: Theme.TEXT_PRIMARY
                            on_press: root.mark_all_present()

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(24)
                        spacing: dp(4)
                        padding: [dp(4), 0]
                        Label:
                            text: "Employee"
                            size_hint_x: 0.2
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: "Role"
                            size_hint_x: 0.12
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: "Status"
                            size_hint_x: 0.15
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: ""
                            size_hint_x: 0.45

                    RefreshableScrollView:
                        refresh_callback: root._rebuild_attendance
                        GridLayout:
                            id: attendance_container
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(2)

            # ========== PAYROLL TAB ==========
            TabbedPanelItem:
                text: "Payroll"
                BoxLayout:
                    orientation: "vertical"
                    spacing: dp(4)
                    padding: dp(4)

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(36)
                        spacing: dp(6)
                        Label:
                            text: "Month:"
                            size_hint_x: 0.08
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "12sp"
                        TextInput:
                            id: payroll_month
                            size_hint_x: 0.08
                            text: ""
                            hint_text: "MM"
                            multiline: False
                            input_filter: "int"
                            input_type: "number"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"
                            on_text: root._rebuild_payroll()
                        Label:
                            text: "Year:"
                            size_hint_x: 0.07
                            color: Theme.TEXT_FIELD_LABEL
                            font_size: "12sp"
                        TextInput:
                            id: payroll_year
                            size_hint_x: 0.1
                            text: ""
                            hint_text: "YYYY"
                            multiline: False
                            input_filter: "int"
                            input_type: "number"
                            foreground_color: Theme.TEXT_PRIMARY
                            background_color: 0.15, 0.15, 0.18, 1
                            font_size: "12sp"
                            on_text: root._rebuild_payroll()
                        Widget:
                        Button:
                            text: "Calculate"
                            size_hint_x: 0.15
                            background_normal: ""
                            background_color: Theme.BTN_SECONDARY
                            color: Theme.TEXT_PRIMARY
                            on_press: root.calculate_payroll()

                    Label:
                        id: payroll_summary
                        size_hint_y: None
                        height: dp(24)
                        text: "Select month/year and tap Calculate."
                        color: Theme.TEXT_SECONDARY
                        font_size: "12sp"
                        halign: "left"

                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(24)
                        spacing: dp(4)
                        padding: [dp(4), 0]
                        Label:
                            text: "Employee"
                            size_hint_x: 0.18
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: "Role"
                            size_hint_x: 0.1
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: "Days"
                            size_hint_x: 0.08
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: "Gross"
                            size_hint_x: 0.12
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: "Net"
                            size_hint_x: 0.12
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: "Status"
                            size_hint_x: 0.12
                            bold: True
                            color: Theme.TEXT_SECONDARY
                            font_size: "12sp"
                        Label:
                            text: ""
                            size_hint_x: 0.2

                    RefreshableScrollView:
                        refresh_callback: root._rebuild_payroll
                        GridLayout:
                            id: payroll_container
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(2)
